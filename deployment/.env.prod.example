# Copy this to deployment/.env.prod and fill in real values.
# NEVER commit .env.prod to git.

# ── App auth (required) ───────────────────────────────────────────────────────
OPENCODE_SERVER_USERNAME=admin
OPENCODE_SERVER_PASSWORD=change_me_to_a_strong_password

# ── API keys ──────────────────────────────────────────────────────────────────
AIRTOP_API_KEY=

# ── Paths ─────────────────────────────────────────────────────────────────────
# Absolute path on the droplet where KB folders (KB10, etc.) live
WORKSPACES_PATH=/home/deploy/workspaces

# ── Domain (used to bake backend URL into frontend build) ─────────────────────
PUBLIC_DOMAIN=yourdomain.com
