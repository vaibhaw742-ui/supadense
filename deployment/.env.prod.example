# Copy this to deployment/.env.prod and fill in real values.
# NEVER commit .env.prod to git.

# ── Server auth (required) ────────────────────────────────────────────────────
OPENCODE_SERVER_USERNAME=admin
OPENCODE_SERVER_PASSWORD=change_me_to_a_strong_password

# ── API keys ──────────────────────────────────────────────────────────────────
AIRTOP_API_KEY=

# ── Optional: Cloudflare AI Gateway (leave blank to bypass) ───────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_GATEWAY_ID=

# ── Optional: GitHub token (for GitHub tool operations) ──────────────────────
GITHUB_TOKEN=

# ── Optional: AWS Bedrock ─────────────────────────────────────────────────────
AWS_BEARER_TOKEN_BEDROCK=

# ── Optional: OpenTelemetry (leave blank to disable) ─────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# ── Paths ─────────────────────────────────────────────────────────────────────
# Absolute path on the droplet where KB folders (KB10, etc.) live
WORKSPACES_PATH=/home/deploy/workspaces

# ── Domain (baked into frontend build) ───────────────────────────────────────
PUBLIC_DOMAIN=yourdomain.com
