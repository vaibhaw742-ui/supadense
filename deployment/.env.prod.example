# ── Auth ──────────────────────────────────────────────────────────────────────
# Strong random string — used to sign JWTs. Generate with: openssl rand -hex 32
SUPADENSE_AUTH_SECRET=

# Admin account seeded on first startup
SUPADENSE_ADMIN_EMAIL=
SUPADENSE_ADMIN_PASSWORD=

# Optional: HTTP basic auth on top of JWT (leave blank to disable)
OPENCODE_SERVER_PASSWORD=
OPENCODE_SERVER_USERNAME=

# ── AI provider keys ──────────────────────────────────────────────────────────
GITHUB_TOKEN=
AWS_BEARER_TOKEN_BEDROCK=
AIRTOP_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_GATEWAY_ID=

# ── Observability (optional) ──────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
