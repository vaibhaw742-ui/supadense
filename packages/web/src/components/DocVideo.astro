---
interface Props {
  src: string
}
const { src } = Astro.props
const base = import.meta.env.BASE_URL.replace(/\/$/, "")
const fullSrc = `${base}${src}`
---

<video
  controls
  width="100%"
  style="border-radius: 8px; margin-bottom: 1.5rem; display: block;"
>
  <source src={fullSrc} type="video/mp4" />
</video>
